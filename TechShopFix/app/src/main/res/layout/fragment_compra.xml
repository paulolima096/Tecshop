<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/btnVoltarCompra"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/user_icon"
            android:contentDescription="Voltar" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Compra"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- CONTEÚDO SCROLLÁVEL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título resumo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seu pedido:"
                android:textColor="#212121"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Lista de itens do pedido -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCompra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Total -->
            <TextView
                android:id="@+id/txtTotalCompra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:text="Total: R$ 0,00"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="4dp" />

            <!-- Campo Nome -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome:"
                android:textColor="#212121"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etNome"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_pesquisa"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textPersonName"
                android:hint=""
                android:layout_marginBottom="12dp" />

            <!-- Campo CEP -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cep:"
                android:textColor="#212121"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etCep"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_pesquisa"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="number"
                android:hint=""
                android:layout_marginBottom="12dp" />

            <!-- Campo Bairro -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bairro:"
                android:textColor="#212121"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etBairro"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_pesquisa"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:hint=""
                android:layout_marginBottom="12dp" />

            <!-- Campo Rua -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rua:"
                android:textColor="#212121"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etRua"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_pesquisa"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:hint=""
                android:layout_marginBottom="16dp" />

            <!-- Botão Finalizar -->
            <Button
                android:id="@+id/btnFinalizarCompra"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Finalizar compra"
                android:backgroundTint="#8B1A1A"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BARRA DE AJUDA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#CC0000"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Ajuda"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>