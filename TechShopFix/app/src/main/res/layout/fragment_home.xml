<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".home.homeFragment">

    <!-- ===== HEADER FIXO ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgPerfil"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/user_icon"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pesquisa"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/pesquisa_icon"/>

            <EditText
                android:id="@+id/etPesquisar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@android:color/transparent"
                android:hint="Pesquisar"
                android:inputType="text"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/btnCarrinho"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="4dp"
            android:src="@drawable/cart_iconpng"/>

    </LinearLayout>
    <!-- ===== FIM HEADER FIXO ===== -->

    <!-- ===== CONTEÚDO SCROLLÁVEL ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner principal -->
            <ImageView
                android:id="@+id/imagemPrincipal"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:scaleType="centerCrop"
                android:src="@drawable/imagem_estatica"/>

            <!-- Espaço entre banners -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"/>

            <!-- Banner PCs -->
            <ImageView
                android:id="@+id/bannerpcs"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:scaleType="centerCrop"
                android:src="@drawable/imagem_estatica2_pcs"/>

            <!-- Espaço entre banners -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"/>

            <!-- Banner design -->
            <ImageView
                android:id="@+id/banner3desing"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:scaleType="centerCrop"
                android:src="@drawable/imagem_estatica3_desing"/>

            <!-- Espaço antes do título -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"/>

            <!-- Título principais ofertas -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#B71C1C"
                android:padding="12dp"
                android:text="Principais Ofertas:"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Lista de produtos -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProdutos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="8dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>
    <!-- ===== FIM CONTEÚDO SCROLLÁVEL ===== -->

</LinearLayout>